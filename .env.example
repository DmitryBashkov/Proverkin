# =====================================================================
# Proverkin :: пример .env. Скопируй в .env и заполни своими значениями.
# =====================================================================

# ----- Postgres -----
POSTGRES_DB=proverkin
POSTGRES_USER=proverkin
POSTGRES_PASSWORD=proverkin

# ----- Telegram -----
TG_BOT_TOKEN=put-your-bot-token-here
# Публичный HTTPS URL, на который Telegram будет слать апдейты.
# Например: https://yourdomain.com/telegram/webhook
TG_WEBHOOK_URL=
TG_WEBHOOK_SECRET=proverkin-secret

# ----- Порты, наружу торчат только эти -----
BOT_PORT=8000
QUIZ_PORT=8001
WEB_PORT=8080

# ----- Расписание квиза (часы по TZ) -----
QUIZ_START_HOUR=10
QUIZ_END_HOUR=11

# ----- OpenRouter -----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GEN_POLL_INTERVAL=60
GEN_BATCH_SIZE=3

# ----- Web GUI -----
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=admin
WEB_SECRET_KEY=change-me-please

# ----- Прочее -----
TZ=Europe/Moscow
