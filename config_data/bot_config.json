{
    "bot": {
        "name": "Booosted Quick Quiz",
        "version": "0.5",
        "admin": "dmitrybashkov"
    },

    "logger": {
        "log_format": "%(asctime)s - [%(levelname)s] - %(name)s - (%(filename)s).%(funcName)s(%(lineno)d) - %(message)s",
        "path": "logs/qqb_bot.log",
        "rotation_time": "midnight",
        "rotation_interval": 1
    },

    "database": {
        "local": {
            "path" : "database/db_bqq.db",
            "backup_directory": "database/backups/"
        },
        "remote": {
            "host": "dimabapd.beget.tech",
            "user": "dimabapd_qqb",
            "password": "",
            "database": "dimabapd_qqb"
        }
    },

    "update": {
        "path": "updates/"
    },

    "export_file_storage": "file_storage/export/",
    "import_file_storage": "file_storage/import/"
}